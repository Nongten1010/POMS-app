POST {{host}}{{apiPrefix}}/device-connections
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}
Content-Type: application/json

{
  "stationId": "STATION_001",
  "protocol": "MSSQL",
  "settings": {
    "hostIp": "192.168.1.254",
    "port": 1433,
    "dbUser": "sensor_user",
