### POMS Backend — Manual API tests
### VS Code: ติดตั้ง extension `humao.rest-client` แล้วกด "Send Request" เหนือแต่ละ block
### IntelliJ/WebStorm: รองรับ native (HTTP Client)

@host = http://localhost:3000
@apiPrefix = /api/v1

###############################################################################
# 1. Health check
###############################################################################

### Health
GET {{host}}/health

###############################################################################
# 2. Login flows (3 user types)
###############################################################################

### 2.1 Login — Admin officer (วีกิจ ชมญาติ)
# @name loginAdmin
POST {{host}}{{apiPrefix}}/auth/login
Content-Type: application/json

{
  "userType": "officer",
  "username": "weekit",
  "departmentID": "2",
  "password": "demo1234"
}

### 2.2 Login — KPM officer (เจ้าหน้าที่ กฝม.)
# @name loginKpm
POST {{host}}{{apiPrefix}}/auth/login
Content-Type: application/json

{
  "userType": "officer",
  "username": "officer_kpm",
  "departmentID": "2",
  "password": "demo1234"
}

### 2.3 Login — Provincial officer (สอจ. สระบุรี)
# @name loginProvincial
POST {{host}}{{apiPrefix}}/auth/login
Content-Type: application/json

{
  "userType": "officer",
  "username": "officer_sng",
  "departmentID": "2",
  "password": "demo1234"
}

### 2.4 Login — Operator (ธนาภรณ์ — 2 บริษัท + 7 โรงงาน)
# @name loginOperator
POST {{host}}{{apiPrefix}}/auth/login
Content-Type: application/json

{
  "userType": "operator",
  "username": "operator_demo",
  "password": "demo1234"
}

### 2.5 Login — Citizen
# @name loginCitizen
POST {{host}}{{apiPrefix}}/auth/login
Content-Type: application/json

{
  "userType": "citizen",
  "username": "citizen_demo",
  "password": "demo1234"
}

###############################################################################
# 3. /me — ดู profile ของตัวเอง (ต้อง login ข้อ 2.1 ก่อน)
###############################################################################

### 3.1 /me ด้วย admin token
GET {{host}}{{apiPrefix}}/auth/me
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}

### 3.2 /me ด้วย operator token
GET {{host}}{{apiPrefix}}/auth/me
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}

###############################################################################
# 4. Error cases (ทดสอบ error handling)
###############################################################################

### 4.1 Wrong password → 401 UNAUTHORIZED
POST {{host}}{{apiPrefix}}/auth/login
Content-Type: application/json

{
  "userType": "officer",
  "username": "weekit",
  "departmentID": "2",
  "password": "WRONG"
}

### 4.2 Missing password → 400 VALIDATION_ERROR
POST {{host}}{{apiPrefix}}/auth/login
Content-Type: application/json

{
  "userType": "officer",
  "username": "weekit",
  "departmentID": "2"
}

### 4.3 Operator without username → 400 VALIDATION_ERROR
POST {{host}}{{apiPrefix}}/auth/login
Content-Type: application/json

{
  "userType": "operator",
  "password": "demo1234"
}

### 4.4 Invalid userType → 400 VALIDATION_ERROR
POST {{host}}{{apiPrefix}}/auth/login
Content-Type: application/json

{
  "userType": "robot",
  "username": "hack",
  "departmentID": "2",
  "password": "demo1234"
}

### 4.5 No Authorization header → 401
GET {{host}}{{apiPrefix}}/auth/me

### 4.6 Invalid Bearer token → 401
GET {{host}}{{apiPrefix}}/auth/me
Authorization: Bearer fake.token.value

### 4.7 Unknown route → 404
GET {{host}}{{apiPrefix}}/does-not-exist

###############################################################################
# 5. Non-existent user
###############################################################################

### 5.1 Officer ที่ไม่มีใน fixtures → 401
POST {{host}}{{apiPrefix}}/auth/login
Content-Type: application/json

{
  "userType": "officer",
  "username": "ghost_user",
  "departmentID": "2",
  "password": "demo1234"
}

### 5.2 Operator unknown username → 401 UNAUTHORIZED
POST {{host}}{{apiPrefix}}/auth/login
Content-Type: application/json

{
  "userType": "operator",
  "username": "unknown_operator",
  "password": "demo1234"
}

###############################################################################
# 6. User permission management (ต้อง login admin ข้อ 2.1 ก่อน)
###############################################################################

### 6.1 ตารางรายชื่อเจ้าหน้าที่
GET {{host}}{{apiPrefix}}/users?search=officer&status=all
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}

### 6.2 ข้อมูลรายคนสำหรับหน้าแก้ไขสิทธิ์
GET {{host}}{{apiPrefix}}/users/1
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}

### 6.3 เพิ่มผู้ใช้งานเจ้าหน้าที่
# @name createManagedUser
POST {{host}}{{apiPrefix}}/users
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
Content-Type: application/json

{
  "username": "officer_api_demo",
  "externalId": "officer_api_demo",
  "userType": "officer",
  "prenameTh": "นาย",
  "firstName": "ทดสอบ",
  "lastName": "สิทธิ์ระบบ",
  "email": "officer_api_demo@example.local",
  "phone": "0800000000",
  "isActive": true,
  "roleCodes": ["diw_central"],
  "profile": {
    "departmentId": "3010000",
    "lineNameTh": "นักวิชาการสิ่งแวดล้อม",
    "levelNameTh": "ปฏิบัติการ"
  }
}

### 6.4 แก้ไขสิทธิ์/สถานะรายคน
PATCH {{host}}{{apiPrefix}}/users/{{createManagedUser.response.body.data.id}}
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
Content-Type: application/json

{
  "isActive": false,
  "roleCodes": ["provincial_office"],
  "profile": {
    "departmentId": "4019000",
    "lineNameTh": "เจ้าหน้าที่ตรวจสอบ",
    "levelNameTh": "ชำนาญการ"
  }
}

### 6.5 ดูสิทธิ์ราย user หลังรวม role + override
GET {{host}}{{apiPrefix}}/users/{{createManagedUser.response.body.data.id}}/permissions
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}

### 6.6 แก้สิทธิ์ราย user แบบ override
PUT {{host}}{{apiPrefix}}/users/{{createManagedUser.response.body.data.id}}/permissions
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
Content-Type: application/json

{
  "permissions": [
    {
      "code": "dashboard:view",
      "effect": "allow",
      "scope": "ALL"
    },
    {
      "code": "factories:edit",
      "effect": "deny"
    }
  ],
  "statusManagement": {
    "selectedParameters": ["ทั้งหมด"],
    "startAt": null,
    "endAt": null,
    "status": "Normal",
    "schedules": []
  }
}

### 6.7 ล้าง override สิทธิ์ราย user
PUT {{host}}{{apiPrefix}}/users/{{createManagedUser.response.body.data.id}}/permissions
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}
Content-Type: application/json

{
  "permissions": []
}

### 6.8 ลบรายคน (soft delete)
DELETE {{host}}{{apiPrefix}}/users/{{createManagedUser.response.body.data.id}}
Authorization: Bearer {{loginAdmin.response.body.data.accessToken}}

###############################################################################
# 7. CEMS/WPMS request forms (ต้อง login operator/เจ้าหน้าที่ก่อน)
###############################################################################

### 7.1 บันทึกฟอร์มคำขอ เพิ่มจุดตรวจวัด
# @name createMeasurementPointRequest
POST {{host}}{{apiPrefix}}/cems-wpms-requests/measurement-points
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}
Content-Type: application/json

{
  "factoryId": "factory-001",
  "factoryName": "บริษัท ทดสอบ จำกัด",
  "factoryRegistrationNo": "3-106-33/50สบ",
  "systemType": "CEMS",
  "contactName": "สมชาย ใจดี",
  "contactPhone": "0812345678",
  "contactEmail": "ops@example.com",
  "measurementPoints": [
    {
      "pointName": "ปล่องระบาย A",
      "pointCode": "STACK-A",
      "pointType": "STACK",
      "latitude": 13.7563,
      "longitude": 100.5018,
      "parameters": ["NOx", "SO2", "PM"],
      "description": "จุดตรวจวัดหลัก",
      "details": {
        "stackShape": "วงกลม",
        "stackDiameter": 1.2,
        "stackWidth": null,
        "stackLength": null,
        "stackShapeOther": null,
        "stackHeight": 30,
        "monitoringHeight": 20,
        "averageFlowRate": 1200,
        "primaryFuel": "ก๊าซธรรมชาติ",
        "connectionDevice": "POMS Box (กรอ.)"
      },
      "documentsAndImages": [
        {
          "title": "ภาพถ่ายปล่อง",
          "fileName": "stack.png",
          "fileUrl": "https://example.com/files/stack.png",
          "fileType": "image/png",
          "fileSize": 1024
        }
      ],
      "measurementInstruments": {
        "converterBrand": "Converter Brand",
        "converterModel": "CV-100",
        "parameters": [
          {
            "parameter": "NOx",
            "technique": "NDIR",
            "range": "0-200",
            "brand": "Siemens",
            "supplier": "ABC Tech",
            "eiaStandard": "120",
            "standardCondition": true,
            "dryBasis": true,
            "oxygenOrExcessAir": true
          }
        ]
      }
    }
  ],
  "remarks": "ขอเพิ่มจุดตรวจวัด"
}

### 7.2 บันทึกฟอร์มคำขอ เพิ่มพารามิเตอร์
# @name createParameterRequest
POST {{host}}{{apiPrefix}}/cems-wpms-requests/parameters
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}
Content-Type: application/json

{
  "factoryId": "factory-001",
  "factoryName": "บริษัท ทดสอบ จำกัด",
  "factoryRegistrationNo": "3-106-33/50สบ",
  "systemType": "CEMS",
  "contactName": "สมชาย ใจดี",
  "contactPhone": "0812345678",
  "contactEmail": "ops@example.com",
  "measurementPoints": [
    {
      "pointName": "ปล่องระบาย A",
      "pointCode": "STACK-A",
      "pointType": "STACK",
      "parameters": ["CO"],
      "description": "เพิ่มพารามิเตอร์ CO",
      "measurementInstruments": {
        "converterBrand": "Converter Brand",
        "converterModel": "CV-100",
        "parameters": [
          {
            "parameter": "CO",
            "technique": "NDIR",
            "range": "0-100",
            "brand": "Siemens",
            "supplier": "ABC Tech",
            "eiaStandard": "50",
            "standardCondition": true,
            "dryBasis": true,
            "oxygenOrExcessAir": true
          }
        ]
      }
    }
  ],
  "remarks": "ขอเพิ่มพารามิเตอร์"
}

### 7.3 ตรวจฟอร์มและเปลี่ยนสถานะเป็นรอเชื่อมต่อ
POST {{host}}{{apiPrefix}}/cems-wpms-requests/{{createMeasurementPointRequest.response.body.data.id}}/status
Authorization: Bearer {{loginKpm.response.body.data.accessToken}}
Content-Type: application/json

{
  "action": "APPROVE_FORM",
  "officerNote": "แบบถูกต้อง"
}

### 7.4 ตรวจฟอร์มและขอให้แก้ไข
POST {{host}}{{apiPrefix}}/cems-wpms-requests/{{createParameterRequest.response.body.data.id}}/status
Authorization: Bearer {{loginKpm.response.body.data.accessToken}}
Content-Type: application/json

{
  "action": "REQUEST_REVISION",
  "revisionReason": "เพิ่มรายละเอียดพารามิเตอร์",
  "officerNote": "ข้อมูลยังไม่ครบ"
}

### 7.5 บันทึกฟอร์ม ตั้งค่าอุปกรณ์ (config) แบบผูกกับคำขอ
# ต้องยิง 7.3 ให้ request เป็น WAITING_CONNECTION ก่อน
# @name createRequestDeviceConfig
POST {{host}}{{apiPrefix}}/cems-wpms-requests/{{createMeasurementPointRequest.response.body.data.id}}/device-configs
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}
Content-Type: application/json

{
  "stationId": "STACK-A",
  "protocol": "MODBUS_TCP",
  "settings": {
    "hostIp": "192.168.1.10",
    "slaveId": 1,
    "port": 502
  },
  "channels": [
    {
      "addressId": 40001,
      "dataType": "NOx",
      "unit": "ppm",
      "valueRange": { "min": 0, "max": 200 },
      "valueFormat": "MEASUREMENT_VALUE",
      "offset": 0,
      "encoding": "UNSIGNED16_BIG_ENDIAN"
    }
  ]
}

### 7.6 รายละเอียดฟอร์ม ตั้งค่าอุปกรณ์ (config) สำหรับดึงข้อมูลลงฟอร์มตามจุดตรวจวัด
GET {{host}}{{apiPrefix}}/cems-wpms-requests/{{createMeasurementPointRequest.response.body.data.id}}/device-configs?stationId=STACK-A
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}

### 7.7 รายละเอียดฟอร์ม ตั้งค่าอุปกรณ์ (config) ราย config
GET {{host}}{{apiPrefix}}/cems-wpms-requests/{{createMeasurementPointRequest.response.body.data.id}}/device-configs/{{createRequestDeviceConfig.response.body.data.id}}
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}

### 7.8 รายการคำขอทั้งหมด สำหรับตารางเจ้าหน้าที่
GET {{host}}{{apiPrefix}}/cems-wpms-requests/table-rows
Authorization: Bearer {{loginKpm.response.body.data.accessToken}}

### 7.9 รายการคำขอเฉพาะผู้ประกอบการ/โรงงานตัวเอง สำหรับตารางผู้ประกอบการ
GET {{host}}{{apiPrefix}}/cems-wpms-requests/table-rows
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}

### 7.10 รายชื่อโรงงาน สำหรับตารางรายชื่อโรงงานผู้ประกอบการ
GET {{host}}{{apiPrefix}}/cems-wpms-requests/operator-factories
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}

### 7.11 รายละเอียดคำขอรายคำขอ สำหรับ PDF / เติมข้อมูลเดิมลงฟอร์มเพิ่มพารามิเตอร์
GET {{host}}{{apiPrefix}}/cems-wpms-requests/{{createMeasurementPointRequest.response.body.data.id}}/detail
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}

### 7.12 รายละเอียดรายจุดตรวจวัดจากทุกคำขอที่เชื่อมต่อแล้ว สำหรับ PDF
GET {{host}}{{apiPrefix}}/cems-wpms-requests/connected-measurement-points
Authorization: Bearer {{loginKpm.response.body.data.accessToken}}

###############################################################################
# 8. Device connection config (ต้อง login operator ข้อ 2.4 หรือ admin ข้อ 2.1 ก่อน)
###############################################################################

### 8.1 Mock test — Modbus TCP
POST {{host}}{{apiPrefix}}/device-connections/test-connection
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}
Content-Type: application/json

{
  "stationId": "STATION_001",
  "protocol": "MODBUS_TCP",
  "settings": {
    "hostIp": "192.168.1.10",
    "slaveId": 1,
    "port": 502
  },
  "channels": [
    {
      "addressId": 40001,
      "dataType": "CO2",
      "unit": "ppm",
      "valueRange": { "min": 0, "max": 200 },
      "valueFormat": "MEASUREMENT_VALUE",
      "offset": 0,
      "encoding": "UNSIGNED16_BIG_ENDIAN"
    }
  ]
}

### 8.2 Mock test — Modbus RTU หนึ่ง connection point + หลายอุปกรณ์ตรวจวัด
POST {{host}}{{apiPrefix}}/device-connections/test-connection
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}
Content-Type: application/json

{
  "stationId": "STATION_001",
  "protocol": "MODBUS_RTU",
  "settings": {
    "comPort": 1,
    "slaveId": 1,
    "baudRate": 9600,
    "parity": "NONE",
    "stopBits": 1,
    "dataBits": 8,
    "valueRange": { "min": 0, "max": 200 },
    "quantity": 2
  },
  "channels": [
    {
      "addressId": 40001,
      "dataType": "CO2",
      "unit": "ppm",
      "valueRange": { "min": 0, "max": 200 },
      "valueFormat": "MEASUREMENT_VALUE",
      "offset": 0,
      "encoding": "UNSIGNED"
    },
    {
      "addressId": 40002,
      "dataType": "O2",
      "unit": "%",
      "valueRange": { "min": 0, "max": 25 },
      "valueFormat": "MEASUREMENT_VALUE",
      "offset": -0.1,
      "encoding": "SIGNED"
    }
  ]
}

### 8.3 Mock test — MSSQL หนึ่ง connection point + หลายอุปกรณ์ตรวจวัด
POST {{host}}{{apiPrefix}}/device-connections/test-connection
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}
Content-Type: application/json

{
  "stationId": "STATION_001",
  "protocol": "MSSQL",
  "settings": {
    "hostIp": "192.168.1.254",
    "port": 1433,
    "dbUser": "sensor_user",
    "dbPass": "secret-pass",
    "dbName": "sensor_db"
  },
  "channels": [
    {
      "addressId": 40001,
      "dataType": "COD",
      "unit": "mg/L",
      "offset": -0.5
    },
    {
      "addressId": 40002,
      "dataType": "BOD",
      "unit": "mg/L",
      "offset": 0
    }
  ]
}

### 8.4 Mock test — MySQL หนึ่ง connection point + หลายอุปกรณ์ตรวจวัด
POST {{host}}{{apiPrefix}}/device-connections/test-connection
Authorization: Bearer {{loginOperator.response.body.data.accessToken}}
Content-Type: application/json

{
  "stationId": "STATION_001",
  "protocol": "MYSQL",
  "settings": {
    "hostIp": "192.168.1.254",
    "port": 3306,
    "dbUser": "sensor_user",
    "dbPass": "secret-pass",
    "dbName": "sensor_db"
  },
  "channels": [
    {
      "addressId": 40001,
      "dataType": "COD",
      "unit": "mg/L",
      "offset": -0.5
    },
    {
      "addressId": 40002,
      "dataType": "BOD",
      "unit": "mg/L",
      "offset": 0
    }
  ]
}

