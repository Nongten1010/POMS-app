# === Application ===
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# === MSSQL Database ===
DB_HOST=localhost
DB_PORT=1433
DB_NAME=POMS
DB_USER=sa
DB_PASSWORD=YourStrongPassword
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# === JWT ===
JWT_SECRET=change-me-to-a-long-random-string-min-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# === Password / bcrypt ===
BCRYPT_SALT_ROUNDS=12

# === Identity Provider ===
# mock = ใช้ fixtures/local เดิม; เปิด DIW_USER_LOGIN_ENABLED เพื่อเพิ่ม DIW UserLogin fallback สำหรับผู้ประกอบการ
IDENTITY_PROVIDER=mock
DIW_USER_LOGIN_ENABLED=false
DIW_OFFICER_LOGIN_ENABLED=false
DIW_USER_LOGIN_URL=https://diwws.diw.go.th/ulogin/v1/UserLogin
DIW_OFFICER_LOGIN_URL=https://diwws.diw.go.th/idiwdpislogin/v1/UserLogin
DIW_USER_LOGIN_CLIENT_ID=
DIW_USER_LOGIN_TIMEOUT_MS=10000
DIW_USER_LOGIN_DEFAULT_PROVINCE_ID=1000

# === External DIW factory database ===
# อ่านข้อมูลโรงงานจริงจาก DIW source table เท่านั้น
FACTORY_DB_HOST=localhost
FACTORY_DB_PORT=1433
FACTORY_DB_NAME=diw
FACTORY_DB_USER=sa
FACTORY_DB_PASSWORD=YourStrongPassword
FACTORY_DB_ENCRYPT=false
FACTORY_DB_TRUST_SERVER_CERTIFICATE=true
FACTORY_DB_SCHEMA=dbo
FACTORY_DB_TABLE=fac_import

# === External DIW boiler database ===
# อ่านขนาดหม้อน้ำจาก sqldiw.diw.go.th ตาราง boiler_list
# หาก user/password เดียวกับ FACTORY_DB ไม่ต้องกำหนด BOILER_DB_USER/BOILER_DB_PASSWORD เพิ่ม
BOILER_DB_HOST=sqldiw.diw.go.th
BOILER_DB_PORT=1433
BOILER_DB_NAME=control
BOILER_DB_USER=sa
BOILER_DB_PASSWORD=YourStrongPassword
BOILER_DB_ENCRYPT=false
BOILER_DB_TRUST_SERVER_CERTIFICATE=true
BOILER_DB_SCHEMA=dbo
BOILER_DB_TABLE=boiler_list

# === External parameter ingestion database ===
# ใช้ user/password/table แยกสำหรับรับค่าพารามิเตอร์เท่านั้น
# หากไม่กำหนด host/port/name จะใช้ DB_HOST/DB_PORT/DB_NAME เดิม
PARAMETER_DB_HOST=localhost
PARAMETER_DB_PORT=1433
PARAMETER_DB_NAME=parameter_ingest
PARAMETER_DB_USER=parameter_ingest_user
PARAMETER_DB_PASSWORD=ChangeThisParameterPassword
PARAMETER_DB_ENCRYPT=false
PARAMETER_DB_TRUST_SERVER_CERTIFICATE=true
PARAMETER_DB_SCHEMA=ingest
PARAMETER_DB_TABLE=parameter_values

# === Integration APIs ===
# Prefer endpoint-scoped keys. INTEGRATION_API_KEYS remains as a temporary fallback for old deployments.
DEVICE_CONFIG_API_KEYS=ChangeThisDeviceConfigApiKey
ALERT_EVENT_API_KEYS=ChangeThisAlertEventApiKey
INTEGRATION_API_KEYS=

# === SMTP email notifications ===
# ใช้ SMTP_SECURE=true สำหรับ SSL port 467; ใช้ SMTP_SECURE=false + SMTP_REQUIRE_TLS=true สำหรับ STARTTLS port 587/2525
SMTP_HOST=mailrelay.uc-workd.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USERNAME=diwmailreply2@diw.mail.go.th
SMTP_PASSWORD=ChangeThisSmtpPassword
SMTP_FROM="POMS Notification <diwmailreply2@diw.mail.go.th>"

# === CORS ===
CORS_ORIGIN=http://localhost:5173

# === Local uploads ===
# Endpoint อัปโหลดเอกสาร/รูปภาพเริ่มจาก local disk และคืน URL กลับไปใส่ documentsAndImages[].fileUrl
# หากย้ายไป object storage ภายหลัง ให้คง response contract เดิมแล้วเปลี่ยน storage implementation
PUBLIC_BASE_URL=http://localhost:3000
UPLOAD_DIR=uploads
UPLOAD_PUBLIC_PATH=/uploads

# === Logging ===
LOG_LEVEL=info
