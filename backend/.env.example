# === Application ===
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# === MSSQL Database ===
DB_HOST=localhost
DB_PORT=1433
DB_NAME=POMS
DB_USER=sa
DB_PASSWORD=YourStrongPassword
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# === JWT ===
JWT_SECRET=change-me-to-a-long-random-string-min-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# === Password / bcrypt ===
BCRYPT_SALT_ROUNDS=12

# === Identity Provider ===
# mock = ใช้ fixtures (demo); external = เรียก API จริงของ กรอ. (ภายหลัง)
IDENTITY_PROVIDER=mock

# === External DIW factory database ===
# อ่านข้อมูลโรงงานจริงจาก DIW source table เท่านั้น
FACTORY_DB_HOST=localhost
FACTORY_DB_PORT=1433
FACTORY_DB_NAME=diw
FACTORY_DB_USER=sa
FACTORY_DB_PASSWORD=YourStrongPassword
FACTORY_DB_ENCRYPT=false
FACTORY_DB_TRUST_SERVER_CERTIFICATE=true
FACTORY_DB_SCHEMA=dbo
FACTORY_DB_TABLE=fac_import

# === External parameter ingestion database ===
# ใช้ user/password/table แยกสำหรับรับค่าพารามิเตอร์เท่านั้น
# หากไม่กำหนด host/port/name จะใช้ DB_HOST/DB_PORT/DB_NAME เดิม
PARAMETER_DB_HOST=localhost
PARAMETER_DB_PORT=1433
PARAMETER_DB_NAME=parameter_ingest
PARAMETER_DB_USER=parameter_ingest_user
PARAMETER_DB_PASSWORD=ChangeThisParameterPassword
PARAMETER_DB_ENCRYPT=false
PARAMETER_DB_TRUST_SERVER_CERTIFICATE=true
PARAMETER_DB_SCHEMA=ingest
PARAMETER_DB_TABLE=parameter_values

# === CORS ===
CORS_ORIGIN=http://localhost:5173

# === Logging ===
LOG_LEVEL=info
