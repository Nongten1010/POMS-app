# === Application ===
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# === MSSQL Database ===
DB_HOST=localhost
DB_PORT=1433
DB_NAME=POMS
DB_USER=sa
DB_PASSWORD=YourStrongPassword
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# === JWT ===
JWT_SECRET=change-me-to-a-long-random-string-min-16-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# === Password / bcrypt ===
BCRYPT_SALT_ROUNDS=12

# === Identity Provider ===
# mock = ใช้ fixtures (demo); external = เรียก API จริงของ กรอ. (ภายหลัง)
IDENTITY_PROVIDER=mock

# === External DIW factory database ===
# mock = ใช้ mock 60,000 records, external = อ่านจาก diw.dbo.fac_import
FACTORY_SOURCE_MODE=mock
FACTORY_DB_HOST=localhost
FACTORY_DB_PORT=1433
FACTORY_DB_NAME=diw
FACTORY_DB_USER=sa
FACTORY_DB_PASSWORD=YourStrongPassword
FACTORY_DB_ENCRYPT=false
FACTORY_DB_TRUST_SERVER_CERTIFICATE=true
FACTORY_DB_SCHEMA=dbo
FACTORY_DB_TABLE=fac_import

# === CORS ===
CORS_ORIGIN=http://localhost:5173

# === Logging ===
LOG_LEVEL=info
